# Leave DATABASE_URL blank to use local SQLite (no Supabase needed)
DATABASE_URL=

# Leave REDIS_URL blank to use in-memory cache (no Upstash needed)
REDIS_URL=

# Optional — only needed to fetch live government data
DATA_GOV_IN_API_KEY=

# Optional — only needed for the AI analyst chat
ANTHROPIC_API_KEY=

ENVIRONMENT=development
